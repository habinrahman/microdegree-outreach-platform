# Runtime profile: dev/development/local skip production hardening. Any other value (e.g. production, staging)
# requires DATABASE_URL, SESSION_SECRET_KEY, and ADMIN_API_KEY (no insecure fallbacks).
# APP_ENV=dev

# Database: default is SQLite (no setup needed). Set below to use PostgreSQL / Supabase.
# DATABASE_URL=sqlite:///./microdegree_outreach.db
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/microdegree_outreach
#
# Pytest: backend/tests/conftest.py forces DATABASE_URL to in-memory SQLite unless you set this
# (use a disposable Postgres database for CI, never your dev/prod URL):
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/placement_outreach_test
# Alembic: optional direct Postgres URL for migrations (avoid Supabase pooler on port 6543 if issues).
# ALEMBIC_DATABASE_URL=postgresql://postgres:...@db.xxx.supabase.co:5432/postgres
# Apply migrations on API startup (optional): ALEMBIC_UPGRADE_ON_START=1
# Postgres: fail fast if host unreachable (seconds)
# DB_CONNECT_TIMEOUT=10
# Default: DB migrations run in background so Uvicorn reports startup immediately (HTTP middleware waits on first real request).
# Set only if you need migrations finished before any request (slower startup):
# BLOCKING_DB_INIT=1

# When set (non-empty), sensitive routers require X-API-Key or X-Admin-Key: /students, /outreach, /campaigns,
# /replies, plus /email-logs and /followup1/send aliases, /oauth/gmail/start, /auth/google.
# OAuth callbacks (/oauth/gmail/callback, /auth/callback) do not require the header (Google redirect).
# Leave empty for fully open local dev. Frontend: VITE_ADMIN_API_KEY must match for browser calls.
ADMIN_API_KEY=

# DEBUG=1 mounts /debug/* (schema introspection) — keep off in production
# DEBUG=0

# Production CORS: lock this down to your dashboard origin(s)
# Example (allow only https://dashboard.example.com):
# CORS_ALLOW_ORIGIN_REGEX=^https://dashboard\.example\.com$

# Logging
LOG_LEVEL=INFO

# Part 2: Gmail OAuth (for campaign emails via Gmail API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Part 3: Frontend URL for OAuth callback redirect (prod domain or local dev)
FRONTEND_URL=http://127.0.0.1:5173

# Part 2: Daily initial emails per student (10-20). Follow-ups do not count.
DAILY_INITIAL_EMAIL_LIMIT=20

# HR health tiers: optional scheduler filter — only send to HRs at or above this tier (A strictest). Empty = off.
# SCHEDULER_MIN_HR_TIER=B

# Optional tuning (defaults work): HR_TIER_A_HEALTH_MIN, HR_TIER_A_OPP_MIN, HR_HEALTH_BOUNCE_SOFT, etc.

# Priority queue (read-only API): blend weights (renormalized if sum ≠ 1). Defaults: 0.30 / 0.25 / 0.20 / 0.15 / 0.10
# PRIORITY_W_FOLLOWUP=0.30
# PRIORITY_W_HR_OPP=0.25
# PRIORITY_W_HR_HEALTH=0.20
# PRIORITY_W_STUDENT=0.15
# PRIORITY_W_WARM=0.10
# PRIORITY_OVER_CONTACT_DAYS=7
# PRIORITY_QUEUE_MAX_ASSIGNMENTS_SCAN=4000

# Phase 2+: scheduler may prefer priority ordering (NOT wired in Phase 1).
# SCHEDULER_USE_PRIORITY_QUEUE=false

# Priority queue Phase 2 — diversity layer (GET /queue/priority?diversified=true)
# PRIORITY_DIV_HR_CAP=2
# PRIORITY_DIV_STUDENT_FLOOR=1
# PRIORITY_DIV_EXPLORATION_PCT=0.075
# PRIORITY_DIV_MMR_ENABLED=false
# PRIORITY_DIV_MMR_LAMBDA=0.22
# PRIORITY_DIV_MMR_WINDOW=24

# --- Backup / recovery (Postgres) ---
# Directory for pg_dump + SQLite copies + manifest JSON (default: ./backups under process cwd)
# BACKUPS_DIR=/var/lib/microdegree/backups
# PG_DUMP_BIN=/usr/bin/pg_dump
# PG_RESTORE_BIN=/usr/bin/pg_restore

# --- Deliverability safety layer (optional; default off) ---
# When enabled, scheduler may pause on global failure storm; worker blocks extreme-risk sends.
# DELIVERABILITY_LAYER=1
# DELIVERABILITY_BOUNCE_WINDOW_HOURS=72
# DELIVERABILITY_BOUNCE_SUPPRESS_THRESHOLD=3
# DELIVERABILITY_SPAM_BLOCK_SCORE=85
# DELIVERABILITY_MIN_REPUTATION_SCORE=25
# DELIVERABILITY_WARMUP_MAX_SENDS_PER_DAY=40
# DELIVERABILITY_WARMUP_STUDENT_DAYS=14
# DELIVERABILITY_WARMUP_FRESH_STUDENT_DAY_CAP=12
# DELIVERABILITY_MIN_SECONDS_BETWEEN_SENDS=0
# DELIVERABILITY_GLOBAL_PAUSE_WINDOW_HOURS=2
# DELIVERABILITY_GLOBAL_PAUSE_MIN_ATTEMPTS=15
# DELIVERABILITY_GLOBAL_PAUSE_FAILURE_PCT=40
# Comma-separated domains for operator rotation hints (informational)
# DELIVERABILITY_SENDER_DOMAINS=mail1.example.com,mail2.example.com

# --- Observability / SRE ---
# Expose Prometheus text at GET /admin/metrics/prometheus (still requires X-API-Key when ADMIN_API_KEY set)
# METRICS_EXPORT_ENABLED=1
# SRE_ALERT_BOUNCE_1H_THRESHOLD=8
# SRE_ALERT_REPLY_RATE_MIN=0.01
# SRE_ALERT_SCHEDULER_STALL_SECONDS=600
# SRE_ALERT_FOLLOWUP_BACKLOG=500
# Rolling 24h success-rate proxy for error budget panel
# SLO_SEND_SUCCESS_TARGET=0.995
